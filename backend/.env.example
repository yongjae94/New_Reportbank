APP_NAME=reportbank-api

# Oracle APP account (APP_RPT) example:
# NOTE: Password contains '@', so it must be URL-encoded as %40.
REPO_DATABASE_URL=oracle+oracledb://APP_RPT:pok1234%40@YONGJAE:1521/?service_name=XE
REPO_SCHEMA=RPT
PII_METADATA_VIEW=RPT.VW_PII_META

# Local scaffold fallback (SQLite):
# REPO_DATABASE_URL=sqlite+aiosqlite:///./reportbank_repo.db
# REPO_SCHEMA=
# PII_METADATA_VIEW=RPT.VW_PII_META

# ITSM callback (optional in local)
ITSM_CALLBACK_URL=
ITSM_CALLBACK_TOKEN=

# Casbin files
CASBIN_MODEL_PATH=casbin/rbac_model.conf
CASBIN_POLICY_PATH=casbin/rbac_policy.csv

# JWT 로그인 (분 단위, 기본 300분)
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=300
