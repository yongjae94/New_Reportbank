APP_NAME=reportbank-api

# Production (Oracle RPT) example:
# REPO_DATABASE_URL=oracle+oracledb://rpt_user:rpt_password@db-host:1521/?service_name=ORCLPDB1
# REPO_SCHEMA=RPT

# Local scaffold default (SQLite):
REPO_DATABASE_URL=sqlite+aiosqlite:///./reportbank_repo.db
REPO_SCHEMA=

# ITSM callback (optional in local)
ITSM_CALLBACK_URL=
ITSM_CALLBACK_TOKEN=

# Casbin files
CASBIN_MODEL_PATH=casbin/rbac_model.conf
CASBIN_POLICY_PATH=casbin/rbac_policy.csv
